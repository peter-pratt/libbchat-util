# Last Modified: Fri 05 Feb 2021 08:13:58 PM UTC
#include <tunables/global>

profile session_router /usr/bin/session_router {
  #include <abstractions/base>
  #include <abstractions/nameservice>

  capability net_admin,
  capability net_bind_service,

  network inet dgram,
  network inet6 dgram,
  network netlink raw,

  /etc/loki/session_router.ini r,
  /dev/net/tun rw,
  /usr/bin/session_router mr,

  owner /{var/,}lib/session_router/ rw,
  owner /{var/,}lib/session_router/** rwk,
  owner ${HOME}/.session_router/ rw,
  owner ${HOME}/.session_router/** rwk,
  owner @{PROC}/@{pid}/task/@{pid}/comm rw,
  owner /tmp/session_router.*/{**,} rw,

  #include if exists <local/usr.bin.session_router>
}
